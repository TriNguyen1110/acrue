generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
}

model Asset {
  ticker       String   @id
  name         String
  exchange     String
  type         String
  sector       String?
  industry     String?
  watcherCount Int      @default(0)
  updatedAt    DateTime @updatedAt

  @@index([name])
}

model User {
  id                  String               @id @default(uuid())
  email               String               @unique
  passwordHash        String
  preferences         Json                 @default("{}")
  createdAt           DateTime             @default(now())
  alerts              Alert[]
  alertRules          AlertRule[]
  portfolioHoldings   PortfolioHolding[]
  portfolioSnapshots  PortfolioSnapshot[]
  pushSubscriptions   PushSubscription[]
  signalScores        SignalScore[]
  simulatedPortfolios SimulatedPortfolio[]
  simulations         Simulation[]
  newsReads           UserNewsRead[]
  watchlist           Watchlist[]
}

model PushSubscription {
  id        String   @id @default(uuid())
  userId    String
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Watchlist {
  id      String   @id @default(uuid())
  userId  String
  ticker  String
  addedAt DateTime @default(now())
  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, ticker])
  @@index([userId])
}

model Alert {
  id          String   @id @default(uuid())
  userId      String
  ticker      String
  type        String
  message     String
  severity    String
  triggeredAt DateTime @default(now())
  read        Boolean  @default(false)
  rules       Json     @default("{}")
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, read])
}

model AlertRule {
  id              String   @id @default(uuid())
  userId          String
  ticker          String
  ruleType        String
  threshold       Float
  cooldownMinutes Int      @default(60)
  createdAt       DateTime @default(now())
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, ticker, ruleType])
  @@index([userId])
}

model NewsArticle {
  id             String         @id @default(uuid())
  tickers        String[]
  headline       String
  summary        String?
  sentiment      String?
  sentimentScore Float?
  impact         String?
  source         String?
  publishedAt    DateTime?
  insight        String?
  createdAt      DateTime       @default(now())
  topics         String[]
  url            String         @unique
  reads          UserNewsRead[]

  @@index([publishedAt(sort: Desc)])
  @@index([tickers])
}

model UserNewsRead {
  userId    String
  articleId String
  readAt    DateTime    @default(now())
  article   NewsArticle @relation(fields: [articleId], references: [id], onDelete: Cascade)
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, articleId])
  @@index([userId])
}

model SignalScore {
  id         String   @id @default(uuid())
  ticker     String
  userId     String
  score      Float
  direction  String
  confidence String
  breakdown  Json
  scoredAt   DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([ticker, scoredAt(sort: Desc)])
  @@index([userId, scoredAt(sort: Desc)])
}

model PortfolioHolding {
  id        String   @id @default(uuid())
  userId    String
  ticker    String
  shares    Float
  avgCost   Float
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, ticker])
  @@index([userId])
}

model PortfolioSnapshot {
  id        String   @id @default(uuid())
  userId    String
  holdings  Json
  metrics   Json
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt(sort: Desc)])
}

model Simulation {
  id        String   @id @default(uuid())
  userId    String
  scenario  Json
  results   Json
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt(sort: Desc)])
}

model SimulatedPortfolio {
  id          String             @id @default(uuid())
  userId      String
  name        String
  description String?
  createdAt   DateTime           @default(now())
  holdings    SimulatedHolding[]
  user        User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt(sort: Desc)])
}

model SimulatedHolding {
  id           String             @id @default(uuid())
  simPortId    String
  ticker       String
  shares       Float
  startPrice   Float
  simPortfolio SimulatedPortfolio @relation(fields: [simPortId], references: [id], onDelete: Cascade)

  @@unique([simPortId, ticker])
  @@index([simPortId])
}
